{
  "priority": 1,
  "request": {
    "method": "POST",
    "urlPath": "/v1/comisiones",
    "bodyPatterns": [
      { "matchesJsonPath": { "expression": "$.transaccion", "matches": ".*(ERR-500|FORCE-ERROR).*" } }
    ]
  },
  "response": {
    "status": 500,
    "headers": { "Content-Type": "application/json" },
    "jsonBody": { "error": "SPIN_INTERNAL", "message": "Falla interna simulada (reintentos / circuit breaker)" }
  }
}
