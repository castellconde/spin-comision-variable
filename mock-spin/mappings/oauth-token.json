{
  "request": {
    "method": "POST",
    "urlPath": "/oauth/token"
  },
  "response": {
    "status": 200,
    "headers": { "Content-Type": "application/json" },
    "jsonBody": {
      "access_token": "mock-access-token-{{randomValue type='UUID'}}",
      "token_type": "Bearer",
      "expires_in": 300
    }
  }
}
