{
  "priority": 1,
  "request": {
    "method": "POST",
    "urlPath": "/v1/comisiones",
    "bodyPatterns": [
      { "matchesJsonPath": { "expression": "$.transaccion", "matches": ".*SLOW.*" } }
    ]
  },
  "response": {
    "status": 200,
    "headers": { "Content-Type": "application/json" },
    "jsonBody": {
      "referencia": "{{jsonPath request.body '$.referencia'}}",
      "concepto": "LATENCIA-SIMULADA",
      "porcentajeComision": 2.50,
      "montoComision": 12.75,
      "moneda": "MXN",
      "estatus": "CALCULADA"
    },
    "fixedDelayMilliseconds": 7000
  }
}
