{
  "priority": 2,
  "request": {
    "method": "POST",
    "urlPath": "/v1/comisiones",
    "headers": {
      "Authorization": { "matches": "Bearer .*" },
      "x-api-key": { "matches": ".+" }
    },
    "bodyPatterns": [
      { "matchesJsonPath": { "expression": "$.servicio", "matches": "SERV-TAE.*" } }
    ]
  },
  "response": {
    "status": 200,
    "headers": { "Content-Type": "application/json" },
    "jsonBody": {
      "referencia": "{{jsonPath request.body '$.referencia'}}",
      "concepto": "{{jsonPath request.body '$.servicio'}}",
      "porcentajeComision": 3.50,
      "montoComision": 17.50,
      "moneda": "MXN",
      "estatus": "CALCULADA"
    },
    "fixedDelayMilliseconds": 80
  }
}
